import Landing from './components/Landing';

export default function App() {
  return <Landing />;
}

function SegmentedSwitch({ value, onChange, options }) {
  const idx = Math.max(0, options.findIndex((o) => o.value === value));
  return (
    <div className="relative inline-flex items-center rounded-2xl border border-slate-200 bg-white p-1 shadow-sm dark:border-gray-700 dark:bg-gray-800">
      <div
        className="absolute inset-y-1 left-1 rounded-xl bg-slate-900 transition-transform duration-200 ease-out dark:bg-white"
        style={{
          width: `calc((100% - 8px) / ${options.length})`,
          transform: `translateX(${idx * 100}%)`,
        }}
        aria-hidden="true"
      />
      {options.map((opt) => {
        const active = opt.value === value;
        return (
          <button
            key={opt.value}
            type="button"
            onClick={() => onChange(opt.value)}
            className={[
              "relative z-10 rounded-xl px-3 py-2 text-xs font-semibold transition-colors",
              "min-w-[64px] sm:min-w-[72px]",
              active ? "text-white dark:text-slate-900" : "text-slate-600 hover:text-slate-900 dark:text-slate-300 dark:hover:text-white",
            ].join(" ")}
          >
            {opt.label}
          </button>
        );
      })}
    </div>
  );
}

const API_BASE_URL = "http://127.0.0.1:5000"; // Hardcoded API endpoint
const THEME_STORAGE_KEY = "theme";

function initializeTheme() {
  // Check localStorage first, default to "light" if not set
  const saved = localStorage.getItem(THEME_STORAGE_KEY);
  return saved || "light";
}

function useTheme() {
  const [theme, setTheme] = useState(() => {
  return localStorage.getItem("theme") || "light";
});

  // Apply theme on mount and whenever it changes
  useEffect(() => {
    const root = document.documentElement;
    
    // Only toggle the "dark" class (Tailwind only recognizes this)
    if (theme === "dark") {
      root.classList.add("dark");
    } else {
      root.classList.remove("dark");
    }
    
    // Persist to localStorage
    localStorage.setItem(THEME_STORAGE_KEY, theme);
    
    // Debug logging
    console.log(`[Theme] Set to: ${theme} | dark class present:`, root.classList.contains("dark"));
  }, [theme]);

  // Toggle theme between light and dark
  const toggleTheme = () => {
    setTheme((prev) => {
      const newTheme = prev === "dark" ? "light" : "dark";
      console.log(`[Theme] Toggling: ${prev} → ${newTheme}`);
      return newTheme;
    });
  };

  return { theme, toggleTheme };
}

export default function App() {
  const fileInputRef = useRef(null);
  const { theme, toggleTheme } = useTheme();
  const [apiBase] = useState(API_BASE_URL); // Fixed API base URL
  const [apiOnline, setApiOnline] = useState(null);

  const [file, setFile] = useState(null);
  const [previewUrl, setPreviewUrl] = useState("");
  const [isDragging, setIsDragging] = useState(false);

  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState("");

  const [result, setResult] = useState(null);
  const [vizMode, setVizMode] = useState("cnn");

  useEffect(() => {

    return () => {
      if (previewUrl) URL.revokeObjectURL(previewUrl);
    };
  }, [previewUrl]);

  useEffect(() => {
    let mounted = true;
    async function ping() {
      const base = clampApiBase(apiBase);
      try {
        const res = await fetch(`${base}/health`, { method: "GET" });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        if (mounted) setApiOnline(true);
      } catch {
        if (mounted) setApiOnline(false);
      }
    }
    ping();
    const t = window.setInterval(ping, 12000);
    return () => {
      mounted = false;
      window.clearInterval(t);
    };
  }, [apiBase]);

  function onPickFile(f) {
    setError("");
    setResult(null);
    const check = validateFile(f);
    if (!check.ok) {
      setFile(null);
      setPreviewUrl("");
      setError(check.msg);
      return;
    }
    setFile(f);
    const nextUrl = URL.createObjectURL(f);
    setPreviewUrl((prev) => {
      if (prev) URL.revokeObjectURL(prev);
      return nextUrl;
    });
  }

  function openPicker() {
    fileInputRef.current?.click();
  }

  async function predict() {
    setError("");
    setResult(null);
    const check = validateFile(file);
    if (!check.ok) {
      setError(check.msg);
      return;
    }

    setIsLoading(true);
    try {
      const base = clampApiBase(apiBase);
      const fd = new FormData();
      fd.append("image", file, file.name);

      const res = await fetch(`${base}/predict`, { method: "POST", body: fd });
      const ct = res.headers.get("content-type") || "";
      const data = ct.includes("application/json") ? await res.json() : null;
      if (!res.ok) {
        const msg = data?.error || data?.message || `Request failed (HTTP ${res.status}).`;
        throw new Error(msg);
      }
      if (!data || (data.status !== "success" && data.status !== "partial")) throw new Error("Unexpected API response.");
      setResult(data);
      setVizMode("cnn");
    } catch (e) {
      setError(String(e?.message || e));
    } finally {
      setIsLoading(false);
    }
  }

  const cnn = result?.cnn || null;
  const vit = result?.vit || null;
  const comparison = result?.comparison || null;
  const explanation = result?.explanation || null;

  const cnnConf = confidenceTone(cnn?.confidence);
  const statusTone = result?.status === "success" ? "bg-emerald-500/15 text-emerald-700 ring-emerald-200 dark:text-emerald-300 dark:ring-emerald-900/60" : "bg-amber-500/15 text-amber-800 ring-amber-200 dark:text-amber-300 dark:ring-amber-900/60";

  const vizPath = explanation?.visualization_path || explanation?.visualization || explanation?.visualizationPath || "";
  const vizUrl = toHeatmapUrl(apiBase, vizPath);

  // Optional (future-proof): if backend ever returns separate images
  const originalPath = explanation?.original_image_path || explanation?.original || "";
  const rawHeatmapPath = explanation?.raw_heatmap_path || explanation?.heatmap_path || explanation?.heatmap || "";
  const overlayPath = explanation?.overlay_heatmap_path || explanation?.overlay || "";

  const cnnPanels = useMemo(() => {
    const o = toHeatmapUrl(apiBase, originalPath);
    const h = toHeatmapUrl(apiBase, rawHeatmapPath);
    const ov = toHeatmapUrl(apiBase, overlayPath);
    if (o && h && ov) return { original: { url: o }, heatmap: { url: h }, overlay: { url: ov } };
    const split = splitComparisonIntoPanels(vizUrl);
    return split;
  }, [apiBase, originalPath, rawHeatmapPath, overlayPath, vizUrl]);

  // ViT visualizations are not part of the current backend contract, but if added later we can support them.
  const vitVizPath =
    explanation?.vit_visualization_path ||
    explanation?.vit_visualization ||
    result?.vit?.visualization_path ||
    result?.vit?.visualization ||
    "";
  const vitVizUrl = toHeatmapUrl(apiBase, vitVizPath);
  const vitPanels = useMemo(() => splitComparisonIntoPanels(vitVizUrl), [vitVizUrl]);
  const hasVitViz = Boolean(vitPanels && vitPanels.original?.url);

  return (
    <div className="min-h-dvh bg-[#F7FAFF] font-[Inter] text-slate-900 dark:bg-[#070A14] dark:text-white transition-colors duration-300">
      {/* Background gradients */}
      <div className="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div className="absolute -left-40 -top-56 h-[560px] w-[760px] rounded-full bg-gradient-to-br from-sky-400/35 via-indigo-500/20 to-violet-500/25 blur-3xl dark:from-sky-500/20 dark:via-indigo-500/15 dark:to-violet-500/20" />
        <div className="absolute -bottom-72 -right-56 h-[640px] w-[820px] rounded-full bg-gradient-to-tr from-violet-500/25 via-indigo-500/20 to-sky-400/25 blur-3xl dark:from-violet-500/20 dark:via-indigo-500/15 dark:to-sky-500/20" />
        <div className="absolute inset-0 opacity-[0.06] [background-image:radial-gradient(#94a3b8_1px,transparent_1px)] [background-size:18px_18px] dark:opacity-[0.08]" />
      </div>

      {/* Navbar */}
      <div className="sticky top-0 z-20 border-b border-slate-200 bg-white backdrop-blur-xl dark:border-gray-700 dark:bg-gray-800 transition-colors duration-300">
        <div className="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
          <div className="flex items-center gap-3">
            <div className="grid h-10 w-10 place-items-center rounded-2xl bg-gradient-to-br from-sky-600 to-violet-600 shadow-sm">
              <div className="h-2.5 w-2.5 rounded-full bg-white shadow-[0_0_0_8px_rgba(255,255,255,0.10)]" />
            </div>
            <div className="leading-tight">
              <div className="font-[Poppins] text-sm font-bold tracking-tight">NeuroAge XAI</div>
              <div className="text-xs text-slate-500 dark:text-slate-400">Brain Age Prediction System</div>
            </div>
          </div>

          <div className="flex items-center gap-3">
            <div className="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-2 text-xs shadow-sm dark:border-gray-700 dark:bg-gray-800">
              <span className={["h-2 w-2 rounded-full", apiOnline === true ? "bg-emerald-500" : apiOnline === false ? "bg-rose-500" : "bg-slate-400"].join(" ")} />
              <span className="text-slate-600 dark:text-slate-300">API</span>
              <span className="font-semibold">{apiOnline === true ? "Online" : apiOnline === false ? "Offline" : "Checking…"}</span>
            </div>

            <IconButton
              title="Toggle theme"
              onClick={toggleTheme}
            >
              <span className="text-base leading-none">{theme === "dark" ? "◐" : "◑"}</span>
              <span>Theme</span>
            </IconButton>
          </div>
        </div>
      </div>

      <main className="mx-auto max-w-6xl px-6 pb-16 pt-10">
        {/* Hero */}
        <div className="grid gap-8 lg:grid-cols-2 lg:items-stretch">
          <div className="space-y-6">
            <div className="space-y-4">
              <h1 className="font-[Poppins] text-4xl font-bold leading-tight tracking-tight text-slate-900 dark:text-white sm:text-5xl">
                Clinical-grade explainability for brain age prediction
              </h1>
              <p className="max-w-xl text-sm leading-7 text-slate-600 dark:text-slate-300">
                Upload an MRI slice to run <span className="font-semibold text-slate-900 dark:text-white">CNN</span> and{" "}
                <span className="font-semibold text-slate-900 dark:text-white">Vision Transformer (ViT)</span> inference, then review{" "}
                <span className="font-semibold text-slate-900 dark:text-white">Grad-CAM</span> attention in a clinical dashboard.
              </p>
            </div>

            <div className="flex flex-wrap gap-2">
              <Tag k="Endpoint" v="/predict" />
              <Tag k="Input" v="PNG/JPG MRI" />
            </div>
          </div>

          {/* Upload Card */}
          <GlassCard className="p-6">
            <div className="flex items-start justify-between gap-4">
              <div>
                <div className="text-sm font-bold text-slate-900 dark:text-white">MRI Upload</div>
                <div className="mt-1 text-xs text-slate-500 dark:text-slate-400">
                  Drag & drop or browse. Sent as form-data key <span className="font-mono font-semibold">image</span>.
                </div>
              </div>
              <button
                type="button"
                onClick={() => {
                  setFile(null);
                  setPreviewUrl((p) => {
                    if (p) URL.revokeObjectURL(p);
                    return "";
                  });
                  setError("");
                  setResult(null);
                }}
                className="rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:bg-slate-50 active:translate-y-0 disabled:opacity-50 dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700"
                disabled={!file && !result}
              >
                Reset
              </button>
            </div>

            <div className="mt-6 space-y-4">
              <input
                ref={fileInputRef}
                type="file"
                accept="image/png,image/jpeg"
                className="hidden"
                onChange={(e) => onPickFile(e.target.files?.[0] || null)}
              />

              <div
                role="button"
                tabIndex={0}
                onClick={() => !isLoading && openPicker()}
                onKeyDown={(e) => {
                  if (e.key === "Enter" || e.key === " ") {
                    e.preventDefault();
                    if (!isLoading) openPicker();
                  }
                }}
                onDragEnter={(e) => {
                  e.preventDefault();
                  if (!isLoading) setIsDragging(true);
                }}
                onDragOver={(e) => {
                  e.preventDefault();
                  if (!isLoading) setIsDragging(true);
                }}
                onDragLeave={(e) => {
                  e.preventDefault();
                  setIsDragging(false);
                }}
                onDrop={(e) => {
                  e.preventDefault();
                  setIsDragging(false);
                  if (isLoading) return;
                  const f = e.dataTransfer.files?.[0] || null;
                  onPickFile(f);
                }}
                className={[
                  "group relative rounded-2xl border border-dashed bg-white p-5 transition",
                  "border-slate-300 hover:-translate-y-0.5 hover:bg-slate-50",
                  "dark:border-gray-600 dark:bg-gray-900 dark:hover:bg-gray-800",
                  isDragging ? "border-violet-400 bg-violet-500/5" : "",
                ].join(" ")}
              >
                <div className="flex items-center justify-between gap-4">
                  <div className="flex items-center gap-3">
                    <div className="grid h-10 w-10 place-items-center rounded-2xl border border-slate-200 bg-white text-slate-700 shadow-sm dark:border-gray-700 dark:bg-gray-800 dark:text-white">
                      ⬆
                    </div>
                    <div className="space-y-0.5">
                      <div className="text-sm font-semibold text-slate-900 dark:text-white">Drag & drop MRI image</div>
                      <div className="text-xs text-slate-500 dark:text-slate-400">PNG, JPG • up to 50 MB</div>
                    </div>
                  </div>
                  <button
                    type="button"
                    onClick={(e) => {
                      e.stopPropagation();
                      openPicker();
                    }}
                    className="rounded-xl bg-gradient-to-br from-sky-600 to-violet-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5 active:translate-y-0"
                    disabled={isLoading}
                  >
                    Browse
                  </button>
                </div>

                {isLoading ? (
                  <div className="absolute inset-x-0 bottom-0 h-1 overflow-hidden rounded-b-2xl">
                    <div className="h-full w-1/2 animate-[sweep_1.1s_cubic-bezier(.2,.8,.2,1)_infinite] bg-gradient-to-r from-sky-500 via-violet-500 to-sky-500 opacity-80" />
                  </div>
                ) : null}
              </div>

              {/* Preview */}
              <div className="rounded-2xl border border-slate-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-800">
                <div className="grid place-items-center rounded-xl bg-slate-50 p-3 dark:bg-gray-900">
                  {previewUrl ? (
                    <img
                      src={previewUrl}
                      alt="MRI preview"
                      className="max-h-56 w-full max-w-full rounded-lg object-contain"
                    />
                  ) : (
                    <div className="py-10 text-center text-xs text-slate-500 dark:text-slate-400">
                      No image selected
                    </div>
                  )}
                </div>

                <div className="mt-4 flex items-center justify-between gap-3">
                  <div className="min-w-0 text-xs text-slate-500 dark:text-slate-400">
                    {file ? (
                      <span className="truncate">
                        {file.name} • {(file.size / (1024 * 1024)).toFixed(2)} MB
                      </span>
                    ) : (
                      "—"
                    )}
                  </div>
                  <div className="flex shrink-0 items-center gap-2">
                    <button
                      type="button"
                      onClick={openPicker}
                      className="rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm transition hover:-translate-y-0.5 hover:bg-slate-50 active:translate-y-0 disabled:opacity-50 dark:border-gray-700 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700"
                      disabled={isLoading}
                    >
                      Replace
                    </button>
                    <button
                      type="button"
                      onClick={() => {
                        setFile(null);
                        setPreviewUrl((p) => {
                          if (p) URL.revokeObjectURL(p);
                          return "";
                        });
                      }}
                      className="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-700 shadow-sm transition hover:-translate-y-0.5 active:translate-y-0 disabled:opacity-50 dark:border-rose-900 dark:bg-rose-950 dark:text-rose-200"
                      disabled={!file || isLoading}
                    >
                      Remove
                    </button>
                  </div>
                </div>
              </div>

              {/* Predict button */}
              <button
                type="button"
                onClick={predict}
                disabled={!file || isLoading}
                className="group inline-flex w-full items-center justify-center gap-3 rounded-2xl bg-gradient-to-br from-sky-600 to-violet-600 px-4 py-3 text-sm font-semibold text-white shadow-[0_16px_34px_rgba(99,102,241,0.22)] transition hover:-translate-y-0.5 active:translate-y-0 disabled:opacity-60"
              >
                {isLoading ? (
                  <span className="h-4 w-4 animate-spin rounded-full border-2 border-white/40 border-t-white" />
                ) : null}
                <span>Predict Brain Age</span>
              </button>

              {error ? (
                <div className="rounded-2xl border border-rose-200/70 bg-rose-500/10 p-4 text-sm text-rose-700 dark:border-rose-900/50 dark:text-rose-200">
                  <div className="font-semibold">Request failed</div>
                  <div className="mt-1 text-xs leading-6">{error}</div>
                </div>
              ) : null}
            </div>
          </GlassCard>
        </div>

        {/* Results */}
        <div className="mt-10 grid gap-6 lg:grid-cols-3 auto-rows-max">
          {/* Prediction card */}
          <GlassCard className="p-6 h-full">
            <div className="flex items-start justify-between gap-4">
              <div>
                <div className="text-sm font-bold">Prediction</div>
                <div className="mt-1 text-xs text-slate-500 dark:text-slate-400">Brain age (CNN primary) + status.</div>
              </div>
              {result ? (
                <span className={["inline-flex items-center gap-2 rounded-full px-3 py-2 text-xs font-semibold ring-1", statusTone].join(" ")}>
                  {result.status === "success" ? "Success" : "Partial"}
                </span>
              ) : (
                <span className="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 dark:border-gray-700 dark:bg-gray-800 dark:text-slate-300">
                  Awaiting input
                </span>
              )}
            </div>

            <div className="mt-6 rounded-2xl border border-slate-200 bg-white p-5 dark:border-gray-700 dark:bg-gray-900">
              <div className="text-xs font-semibold text-slate-500 dark:text-slate-400">Predicted age</div>
              <div className="mt-2 font-[Poppins] text-5xl font-bold tracking-tight">{cnn?.predicted_age != null ? formatAge(cnn.predicted_age) : "—"}</div>
              <div className="mt-1 text-xs text-slate-500 dark:text-slate-400">years</div>
            </div>

            <div className="mt-4 flex items-center justify-between gap-3">
              <div className="text-xs text-slate-500 dark:text-slate-400">Confidence</div>
              <span className={["inline-flex items-center rounded-full px-3 py-2 text-xs font-semibold ring-1", cnnConf.cls].join(" ")}>
                {cnn?.confidence ? cnnConf.label : "—"}
              </span>
            </div>
          </GlassCard>

          {/* Model comparison */}
          <GlassCard className="p-6 h-full">
            <div>
              <div className="text-sm font-bold">Model comparison</div>
              <div className="mt-1 text-xs text-slate-500 dark:text-slate-400">CNN vs ViT outputs in a clean layout.</div>
            </div>

            <div className="mt-6 grid gap-3 sm:grid-cols-2">
              <div className="rounded-2xl border border-slate-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-900">
                <div className="text-xs font-semibold text-slate-500 dark:text-slate-400">CNN</div>
                <div className="mt-2 font-[Poppins] text-3xl font-bold">{cnn?.predicted_age != null ? `${formatAge(cnn.predicted_age)}y` : "—"}</div>
                <div className="mt-1 text-xs text-slate-500 dark:text-slate-400">{cnn?.confidence ? `Conf: ${String(cnn?.confidence)}` : "—"}</div>
              </div>
              <div className="rounded-2xl border border-slate-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-900">
                <div className="text-xs font-semibold text-slate-500 dark:text-slate-400">ViT</div>
                <div className="mt-2 font-[Poppins] text-3xl font-bold">{vit?.status === "success" ? `${formatAge(vit?.predicted_age)}y` : "—"}</div>
                <div className="mt-1 text-xs text-slate-500 dark:text-slate-400">
                  {vit?.status === "success" ? `Conf: ${String(vit?.confidence)}` : vit?.message || "Not available"}
                </div>
              </div>
            </div>

            <div className="mt-4 rounded-2xl border border-slate-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-900">
              <div className="flex items-center justify-between gap-3 text-xs">
                <span className="text-slate-500 dark:text-slate-400">Age difference</span>
                <span className="font-semibold">{comparison?.difference != null ? `${Number(comparison.difference).toFixed(1)} yrs` : "—"}</span>
              </div>
              <div className="mt-2 flex items-center justify-between gap-3 text-xs">
                <span className="text-slate-500 dark:text-slate-400">Better confidence</span>
                <span className="font-semibold">{comparison?.better_confidence ? String(comparison.better_confidence).toUpperCase() : "—"}</span>
              </div>
            </div>
          </GlassCard>

          {/* Grad-CAM visualization */}
          <GlassCard className="p-6 lg:col-span-2">
            <div className="flex items-start justify-between gap-4">
              <div>
                <div className="text-sm font-bold">Grad-CAM visualization</div>
                <div className="mt-1 text-xs text-slate-500 dark:text-slate-400">Explainability heatmap with model insights.</div>
              </div>

              {hasVitViz ? (
                <SegmentedSwitch
                  value={vizMode}
                  onChange={setVizMode}
                  options={[
                    { value: "cnn", label: "CNN" },
                    { value: "vit", label: "ViT" },
                  ]}
                />
              ) : null}
            </div>

            {/* Grad-CAM Metadata */}
            {result && (
              <div className="mt-6 grid gap-3 grid-cols-2 sm:grid-cols-3 mb-6">
                <div className="rounded-2xl border border-slate-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-900">
                  <div className="text-xs font-semibold text-slate-500 dark:text-slate-400">Predicted Brain Age</div>
                  <div className="mt-2 font-[Poppins] text-2xl font-bold">{cnn?.predicted_age != null ? `${formatAge(cnn.predicted_age)}y` : "—"}</div>
                </div>
                <div className="rounded-2xl border border-slate-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-900">
                  <div className="text-xs font-semibold text-slate-500 dark:text-slate-400">Model Used</div>
                  <div className="mt-2 font-[Poppins] text-2xl font-bold">{vizMode === "vit" ? "ViT" : "CNN"}</div>
                </div>
                <div className="rounded-2xl border border-slate-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-900">
                  <div className="text-xs font-semibold text-slate-500 dark:text-slate-400">Confidence</div>
                  <div className="mt-2 text-xl font-bold">
                    {vizMode === "vit" ? (vit?.confidence ? String(vit.confidence).charAt(0).toUpperCase() + String(vit.confidence).slice(1) : "—") : (cnn?.confidence ? String(cnn.confidence).charAt(0).toUpperCase() + String(cnn.confidence).slice(1) : "—")}
                  </div>
                </div>
              </div>
            )}

            {/* Interpretation Text */}
            {result && (
              <div className="mb-6 rounded-2xl border border-slate-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-900">
                <div className="text-xs font-semibold text-slate-600 dark:text-slate-300 mb-2">How to read this heatmap:</div>
                <div className="text-xs leading-6 text-slate-600 dark:text-slate-400">
                  The Grad-CAM heatmap highlights brain regions that most influenced the age prediction. 
                  <span className="font-semibold"> Red areas</span> indicate high attention (strong predictive regions), 
                  <span className="font-semibold"> yellow</span> indicates medium attention, and 
                  <span className="font-semibold"> blue</span> indicates low attention.
                </div>
              </div>
            )}

            <div className="rounded-2xl border border-slate-200 bg-white p-4 dark:border-gray-700 dark:bg-gray-900">
              {(() => {
                const panels = vizMode === "vit" ? vitPanels : cnnPanels;
                if (!panels) {
                  return <div className="py-10 text-center text-xs text-slate-500 dark:text-slate-400">No visualization yet</div>;
                }
                const items = [
                  { key: "original", title: "Original MRI", hint: "Original", ...panels.original },
                  { key: "heatmap", title: "Raw Heatmap", hint: "Heatmap", ...panels.heatmap },
                  { key: "overlay", title: "Overlay", hint: "Overlay", ...panels.overlay },
                ];

                return (
                  <div className="space-y-4">
                    <div className="grid gap-3 md:grid-cols-3">
                      {items.map((it) => (
                        <div key={it.key} className="space-y-2">
                          <div className="text-[11px] font-semibold tracking-wide text-slate-500 dark:text-slate-400">
                            {it.hint}
                          </div>
                          <div className="group relative overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 shadow-sm dark:border-gray-700 dark:bg-gray-800">
                            {/* If we only have a combined comparison image, use background cropping. Otherwise use img. */}
                            {it.bgPos ? (
                              <div
                                className="aspect-[6/5] w-full transition-transform duration-300 ease-out group-hover:scale-[1.10]"
                                style={{
                                  backgroundImage: `url("${it.url}")`,
                                  backgroundSize: "300% 100%",
                                  backgroundPosition: it.bgPos,
                                  backgroundRepeat: "no-repeat",
                                }}
                                aria-label={it.title}
                              />
                            ) : (
                              <img
                                src={it.url}
                                alt={it.title}
                                className="aspect-[6/5] w-full object-contain p-2 transition-transform duration-300 ease-out group-hover:scale-[1.04]"
                                onError={(e) => {
                                  e.currentTarget.style.display = "none";
                                  setError("Heatmap failed to load. Please confirm /heatmap/<filename> is reachable on the backend.");
                                }}
                              />
                            )}
                            <div className="pointer-events-none absolute inset-0 bg-gradient-to-tr from-white/0 via-white/0 to-white/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100 dark:to-white/5" />
                          </div>
                        </div>
                      ))}
                    </div>

                    <div className="flex items-center justify-between text-[11px] text-slate-500 dark:text-slate-400">
                      <span>Legend: Red=High • Yellow=Medium • Blue=Low</span>
                      <span className="font-mono">
                        {vizMode === "vit"
                          ? (vitVizUrl ? basenameFromPath(vitVizUrl) : "")
                          : (vizUrl ? basenameFromPath(vizUrl) : "")}
                      </span>
                    </div>
                  </div>
                );
              })()}
            </div>
          </GlassCard>
        </div>
      </main>

      <style>{`
        @keyframes sweep { 0%{transform:translateX(-70%)} 100%{transform:translateX(140%)} }
      `}</style>
    </div>
  );
}
